/**
 * Wrangler 配置文件示例
 * 复制此文件为 wrangler.jsonc 并填入你的真实配置
 * 重要：wrangler.jsonc 不应该提交到 git！
 * 
 * 敏感配置（如数据库 ID、KV ID）请通过以下方式设置：
 * - 本地开发：在 .dev.vars 文件中配置
 * - 生产环境：使用 wrangler secret put <变量名>
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "my-anime-blog",
	"main": "./workers/app.ts",
	"compatibility_date": "2025-04-04",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"assets": {
		"directory": "./build/client",
		"binding": "ASSETS"
	},
	"vars": {
		"ENVIRONMENT": "development"
	},
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "anime_db",
			"database_name": "my-anime-blog",
			"database_id": "REPLACE_WITH_YOUR_PROD_DB_ID",
			"remote": true
		},
		{
			"binding": "anime_db_local",
			"database_name": "anime-db-local",
			"database_id": "REPLACE_WITH_YOUR_LOCAL_DB_ID"
		}
	],
	"kv_namespaces": [
		{
			"binding": "CACHE_KV",
			"id": "REPLACE_WITH_YOUR_KV_ID"
		}
	],
	"r2_buckets": [
		{
			"binding": "IMAGES_BUCKET",
			"bucket_name": "REPLACE_WITH_YOUR_R2_BUCKET_NAME"
		}
	],
	"ai": {
		"binding": "AI"
	},
	"analytics_engine_datasets": [
		{
			"binding": "ANALYTICS",
			"dataset": "REPLACE_WITH_YOUR_DATASET_NAME"
		}
	],
	"triggers": {
		"crons": [
			"0 */6 * * *"
		]
	}
}
