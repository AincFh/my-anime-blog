# ============================================================
# A.T. Field 项目环境变量示例
# 复制此文件为 .dev.vars 用于本地开发
# 重要：确保 .dev.vars 不会提交到 git！
# ============================================================

# ----- Cloudflare Secrets (必须通过 wrangler secret put 设置) -----
# 支付签名密钥
PAYMENT_SECRET=your_payment_secret_here

# CSRF 防护密钥
CSRF_SECRET=your_csrf_secret_here

# 会话签名密钥
SESSION_SECRET=your_session_secret_here

# Turnstile 反机器人验证密钥
TURNSTILE_SECRET=your_turnstile_secret_here

# Cloudflare API Token (用于清除缓存等管理操作)
CF_API_TOKEN=your_cf_api_token_here

# Cloudflare Zone ID
CF_ZONE_ID=your_cf_zone_id_here

# Notion Integration Token
NOTION_TOKEN=secret_your_notion_token_here

# ----- Notion 数据库 ID (通过 wrangler secret put 设置) -----
# Notion 文章数据库 ID
NOTION_DATABASE_ID=your_notion_database_id

# Notion 时光机数据库 ID
NOTION_TIMELINE_DATABASE_ID=your_notion_timeline_database_id

# Notion 网站设定数据库 ID
NOTION_SITE_CONTENT_DATABASE_ID=your_notion_site_content_database_id

# Notion 更新日志数据库 ID
NOTION_CHANGELOG_DATABASE_ID=your_notion_changelog_database_id

# Notion 公告数据库 ID
NOTION_ANNOUNCEMENT_DATABASE_ID=your_notion_announcement_database_id

# ----- 可选配置 -----
# 支付回调 IP 白名单 (逗号分隔)
PAYMENT_CALLBACK_IPS=127.0.0.1,::1

# 管理员注册邀请码 (可选)
ADMIN_INVITE_CODE=
