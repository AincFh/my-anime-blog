## 路由错误处理

### Loader 错误处理

```typescript
// ✅ 正确处理 Loader 错误
export async function loader({ params, env }: LoaderFunctionArgs) {
  const slug = params.slug;

  try {
    const article = await articleService.getBySlug(env, slug);

    if (!article) {
      throw new NotFoundError('文章', slug);
    }

    return successResponse({ article });
  } catch (error) {
    if (error instanceof AppError) {
      throw data(error.toJSON(), { status: error.statusCode });
    }

    logger.error('加载文章失败', {
      slug,
      error: error instanceof Error ? error.message : String(error),
    });

    throw data(
      { code: 'INTERNAL_ERROR', message: '加载文章失败' },
      { status: 500 }
    );
  }
}
```

### Action 错误处理

```typescript
// ✅ Action 统一错误处理
export async function action({ request, env }: ActionFunctionArgs) {
  const contentType = request.headers.get('Content-Type') ?? '';

  if (!contentType.includes('application/json') && !contentType.includes('form')) {
    return errorResponse(
      new BadRequestError('无效的请求类型'),
      { requestId: getRequestId(request) }
    );
  }

  try {
    const body = contentType.includes('application/json')
      ? await request.json()
      : Object.fromEntries(await request.formData());

    const result = await articleService.create(env, body);

    return successResponse(result, { requestId: getRequestId(request) });
  } catch (error) {
    if (error instanceof ValidationError) {
      return errorResponse(error, { requestId: getRequestId(request) });
    }

    if (error instanceof UnauthorizedError) {
      return errorResponse(error, { requestId: getRequestId(request) });
    }

    logger.error('创建文章失败', {
      error: error instanceof Error ? error.message : String(error),
    });

    return errorResponse(
      new InternalError('创建文章失败'),
      { requestId: getRequestId(request) }
    );
  }
}
```

