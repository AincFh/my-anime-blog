# React Router v7 开发规范

## 数据获取规则

### 1. Loader 函数（必须优先使用）

```typescript
// ✅ 正确 - 使用 Loader 获取数据
import { data } from 'react-router';

export async function loader({ request, params, env }: LoaderFunctionArgs) {
  const slug = params.slug;
  
  const article = await env.DB
    .prepare('SELECT * FROM articles WHERE slug = ?')
    .bind(slug)
    .first();
  
  if (!article) {
    throw data('文章不存在', { status: 404 });
  }
  
  return Response.json({ article });
}

// ❌ 禁止 - 在客户端使用 useEffect 获取数据
function ArticlePage() {
  const [article, setArticle] = useState(null);
  
  useEffect(() => {
    fetch(`/api/article/${slug}`).then(res => res.json());
  }, [slug]);
  
  // ...
}
```

### 2. Action 函数（表单提交必须使用）

```typescript
export async function action({ request, env }: ActionFunctionArgs) {
  const formData = await request.formData();
  const title = formData.get('title') as string;
  
  // 验证数据
  const result = createArticleSchema.safeParse({ title });
  if (!result.success) {
    return Response.json(
      { success: false, errors: result.error.flatten() },
      { status: 400 }
    );
  }
  
  // 执行业务逻辑
  await env.DB
    .prepare('INSERT INTO articles (title) VALUES (?)')
    .bind(result.data.title)
    .run();
  
  return Response.json({ success: true });
}
```

### 3. useFetcher（适合非导航交互）

```typescript
import { useFetcher } from 'react-router';

function LikeButton({ articleId }: { articleId: number }) {
  const fetcher = useFetcher();
  const isLiking = fetcher.state !== 'idle';
  
  return (
    <fetcher.Form method="post" action={`/api/article/${articleId}/like`}>
      <button type="submit" disabled={isLiking}>
        {isLiking ? '点赞中...' : '点赞'}
      </button>
    </fetcher.Form>
  );
}
```

## 组件架构

### 1. 服务端组件优先

```typescript
// ✅ 默认使用服务端组件
import type { LoaderFunctionArgs } from 'react-router';

export async function loader({ env }: LoaderFunctionArgs) {
  const articles = await getFeaturedArticles(env);
  return { articles };
}

// 服务端组件 - 直接访问 loader 数据
export default function HomePage({ loaderData }: Route.ComponentProps) {
  const { articles } = loaderData;
  
  return (
    <main>
      {articles.map(article => (
        <ArticleCard key={article.id} article={article} />
      ))}
    </main>
  );
}
```

### 2. 客户端组件（需要交互时添加）

```typescript
// ✅ 添加 'use client' 指令
'use client';

import { useState } from 'react';

interface Props {
  initialCount: number;
}

export function Counter({ initialCount }: Props) {
  const [count, setCount] = useState(initialCount);
  
  return (
    <button onClick={() => setCount(c => c + 1)}>
      点击次数: {count}
    </button>
  );
}
```

