## 错误处理

### 1. ErrorBoundary 组件

```typescript
import { isRouteErrorResponse, useRouteError } from 'react-router';

export function ErrorBoundary() {
  const error = useRouteError();
  
  if (isRouteErrorResponse(error)) {
    return (
      <div className="error-page">
        <h1>{error.status}</h1>
        <p>{error.statusText}</p>
      </div>
    );
  }
  
  return (
    <div className="error-page">
      <h1>出错了</h1>
      <p>{error instanceof Error ? error.message : '未知错误'}</p>
    </div>
  );
}
```

### 2. 路由级别错误处理

```typescript
// app/routes/articles.$slug.tsx
export function ErrorBoundary() {
  return (
    <div className="min-h-screen flex items-center justify-center">
      <div className="text-center">
        <h1 className="text-4xl font-bold text-red-500">404</h1>
        <p className="text-gray-400 mt-2">文章不存在或已被删除</p>
      </div>
    </div>
  );
}
```

## 路由结构规范

### 标准路由模式

```typescript
// 路由命名规范
app/
├── routes/
│   ├── _index.tsx                    # 首页 /
│   ├── articles._index.tsx           # 文章列表 /articles
│   ├── articles.$slug.tsx            # 文章详情 /articles/:slug
│   ├── articles.new.tsx             # 创建文章 /articles/new
│   ├── articles.$slug.edit.tsx       # 编辑文章 /articles/:slug/edit
│   ├── api.articles.tsx             # 文章 API
│   ├── api.articles.$id.tsx         # 单篇文章 API
│   └── _dashboard.tsx                # 仪表盘布局
│       ├── _dashboard.index.tsx     # 仪表盘首页
│       └── _dashboard.settings.tsx  # 仪表盘设置
```

## 加载状态

### Suspense 边界

```typescript
import { Suspense } from 'react';
import { Await, useLoaderData } from 'react-router';

export async function loader({ env }: LoaderFunctionArgs) {
  const articles = getArticles(env);
  const popularTags = getPopularTags(env);
  
  return { articles, popularTags };
}

export default function ArticlesPage() {
  const { articles, popularTags } = useLoaderData<typeof loader>();
  
  return (
    <div className="grid grid-cols-3 gap-6">
      <div className="col-span-2">
        <Suspense fallback={<ArticleListSkeleton />}>
          <Await resolve={articles}>
            {(data) => <ArticleList articles={data} />}
          </Await>
        </Suspense>
      </div>
      <div className="col-span-1">
        <Suspense fallback={<TagsSkeleton />}>
          <Await resolve={popularTags}>
            {(data) => <PopularTags tags={data} />}
          </Await>
        </Suspense>
      </div>
    </div>
  );
}
```

## 类型安全

### 使用 TypeScript 严格模式

```typescript
// 所有路由参数必须定义类型
export async function loader({ params }: LoaderFunctionArgs) {
  // 明确 params.slug 类型
  const slug = params.slug as string;
  
  // 使用 zod 验证参数
  const result = slugSchema.safeParse(slug);
  if (!result.success) {
    throw data('无效的文章slug', { status: 400 });
  }
}
```

## 性能优化

1. **避免不必要的水合**
   - 使用 `clientLoader` 减少客户端 JS
   - 使用 `hydrate` 控制水合行为

2. **预加载数据**
   - 使用 `useNavigation` 显示预加载状态
   - 使用 `usePrefetch` 预加载将来可能需要的路由

3. **缓存策略**
   - 使用 `Cache-Control` 头控制缓存
   - 利用 React Router 的缓存机制
