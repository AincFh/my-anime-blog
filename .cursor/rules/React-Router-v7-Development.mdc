## 类型安全

### 使用 TypeScript 严格模式

```typescript
// 所有路由参数必须定义类型
export async function loader({ params }: LoaderFunctionArgs) {
  // 明确 params.slug 类型
  const slug = params.slug as string;

  // 使用 zod 验证参数
  const result = slugSchema.safeParse(slug);
  if (!result.success) {
    throw data('无效的文章slug', { status: 400 });
  }
}
```

