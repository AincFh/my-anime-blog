## 函数规范

### 函数声明

```typescript
// ✅ 显式返回类型
function greet(name: string): string {
  return `你好，${name}！`;
}

// ✅ 箭头函数用于简短函数
const double = (n: number): number => n * 2;

// ✅ async 函数必须声明返回类型
async function fetchUser(id: number): Promise<User> {
  const response = await fetch(`/api/users/${id}`);
  return response.json();
}
```

### 参数处理

```typescript
// ✅ 必选参数在前，可选参数在后
function createButton(
  label: string,           // 必选
  onClick: () => void,      // 必选
  variant?: 'primary' | 'secondary',  // 可选
  disabled = false          // 可选，默认值
): JSX.Element { }

// ❌ 参数顺序混乱
function createButton(
  disabled = false,
  variant?: 'primary' | 'secondary',
  label: string,
  onClick: () => void,
): JSX.Element { }
```

### 错误处理

```typescript
// ✅ 使用 try-catch 并重新抛出有意义错误
async function getArticle(slug: string): Promise<Article> {
  try {
    const article = await articleRepository.findBySlug(env.DB, slug);
    
    if (!article) {
      throw new NotFoundError(`文章不存在: ${slug}`);
    }
    
    return article;
  } catch (error) {
    if (error instanceof NotFoundError) {
      throw error;
    }
    logger.error('获取文章失败', { slug, error });
    throw new InternalError('获取文章时发生错误');
  }
}

// ✅ 使用 Result 模式处理错误
type Result<T, E = Error> = 
  | { ok: true; value: T }
  | { ok: false; error: E };

async function getArticle(slug: string): Promise<Result<Article>> {
  try {
    const article = await articleRepository.findBySlug(env.DB, slug);
    return article 
      ? { ok: true, value: article }
      : { ok: false, error: new NotFoundError('文章不存在') };
  } catch (error) {
    return { ok: false, error: error as Error };
  }
}
```

