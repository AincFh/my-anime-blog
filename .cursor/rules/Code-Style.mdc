```

## 代码组织

### import 语句顺序

```typescript
// 1. React 相关
import { useState, useEffect } from 'react';
import { useFetcher } from 'react-router';

// 2. 第三方库
import { z } from 'zod';
import bcrypt from 'bcryptjs';

// 3. 项目内部 - 绝对导入
import { Button, Card } from '~/components/ui';
import { articleService } from '~/services/article';
import type { Article } from '~/types/article';

// 4. 项目内部 - 相对导入
import { formatDate } from '../utils/date';
import { logger } from '~/utils/logger';

// 5. 类型导入
import type { LoaderFunctionArgs } from 'react-router';
```

### 模块导出

```typescript
// ✅ 统一使用命名导出
export function ArticleCard() { }
export function ArticleList() { }

// ✅ 统一使用命名导入
import { ArticleCard, ArticleList } from './components';

// ✅ 导出类型
export type { Article, ArticleInput } from './types/article';

// ✅ 默认导出仅用于根组件
export default function App() { }
```

## 格式规范

### 缩进和空格

```typescript
// ✅ 使用 2 空格缩进
function Example() {
  if (condition) {
    doSomething();
  }
}

// ✅ 操作符周围添加空格
const sum = a + b;
const fullName = firstName + ' ' + lastName;
const isValid = value !== null;

// ❌ 移除不必要的空格
const sum = a+b;  // 错误
const name = firstName+lastName;  // 错误
```

### 引号使用

```typescript
// ✅ 字符串优先使用单引号
const message = '你好，世界！';
const path = '/api/users';

// ✅ JSX 属性使用双引号
return <div className="container">内容</div>;

// ✅ 模板字符串用于复杂字符串
const greeting = `用户 ${name}，您好！`;
const sql = `SELECT * FROM users WHERE id = ${userId}`;
```

### 分号使用

```typescript
// ✅ 始终使用分号
const name = '张三';
function greet() {
  return '你好';
}
```

## 代码块顺序（类/组件内）

```typescript
export class ArticleService {
  // 1. 静态属性和静态方法
  static defaultConfig = { /* ... */ };
  static createInstance() { /* ... */ };
  
  // 2. 实例属性
  private cache: Map<string, Article>;
  private env: Env;
  
  // 3. 构造函数
  constructor(env: Env) {
    this.env = env;
    this.cache = new Map();
  }
  
  // 4. 公共方法（按重要性/使用频率排序）
  async getArticle(id: number): Promise<Article> { }
  async createArticle(data: ArticleInput): Promise<Article> { }
  async updateArticle(id: number, data: ArticleInput): Promise<Article> { }
  
  // 5. 私有方法
  private async fetchFromDb(id: number): Promise<Article | null> { }
  private invalidateCache(key: string): void { }
}
```

## 禁止的做法

```typescript
// ❌ 禁止使用 var
var name = '张三';  // 使用 let 或 const

// ❌ 禁止使用 ==（隐式类型转换）
if (value == null) { }  // 使用 === 或 == null

// ❌ 禁止使用 eval
eval('console.log("危险")');

// ❌ 禁止使用 with
with (obj) {
  console.log(name);  // 不清晰
}

// ❌ 禁止修改函数参数
function processData(data: Config) {
  data.timeout = 5000;  // 不要这样做！
  // ...
}

// ❌ 禁止使用 for...in 遍历数组
const arr = [1, 2, 3];
for (const i in arr) {
  console.log(arr[i]);  // 不推荐
}

// ❌ 禁止使用 continue
for (const item of items) {
  if (skip(item)) continue;  // 优先使用 if-else 或 filter
  process(item);
}
```
