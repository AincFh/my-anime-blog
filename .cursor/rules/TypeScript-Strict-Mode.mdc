## React 组件类型

### 1. Props 接口定义

```typescript
// ✅ 推荐 - 使用 interface 定义 props
interface ButtonProps {
  variant?: 'primary' | 'secondary' | 'danger';
  size?: 'sm' | 'md' | 'lg';
  disabled?: boolean;
  children: React.ReactNode;
  onClick?: () => void;
}

// ✅ 使用 React.ComponentPropsWithoutRef 扩展原生元素
interface CustomInputProps extends React.ComponentPropsWithoutRef<'input'> {
  label: string;
  error?: string;
}
```

### 2. 事件处理类型

```typescript
// ✅ 正确的事件处理类型
function handleClick(event: React.MouseEvent<HTMLButtonElement>) {
  event.currentTarget;
}

function handleChange(event: React.ChangeEvent<HTMLInputElement>) {
  event.target.value;
}

function handleSubmit(event: React.FormEvent<HTMLFormElement>) {
  event.preventDefault();
}
```

### 3. Loader 和 Action 类型

```typescript
import type { ActionFunctionArgs, LoaderFunctionArgs } from 'react-router';
import { data } from 'react-router';
import { z } from 'zod';

const CreateArticleSchema = z.object({
  title: z.string().min(1).max(200),
  content: z.string().min(1),
});

export async function action({ request, env }: ActionFunctionArgs) {
  const formData = await request.formData();
  const result = CreateArticleSchema.safeParse(Object.fromEntries(formData));

  if (!result.success) {
    return data(
      { success: false, errors: result.error.flatten() },
      { status: 400 }
    );
  }

  return data({ success: true });
}
```

