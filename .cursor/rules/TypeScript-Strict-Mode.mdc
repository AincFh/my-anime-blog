## 类型文件组织

### 目录结构

```
app/types/
├── index.ts           # 导出所有类型
├── env.ts             # 环境变量类型
├── article.ts         # 文章相关类型
├── user.ts            # 用户相关类型
└── api.ts             # API 响应类型
```

### 类型导出规范

```typescript
// app/types/article.ts

// 导出所有相关类型
export interface Article {
  id: number;
  slug: string;
  title: string;
  content: string;
  excerpt?: string;
  coverImage?: string;
  status: ArticleStatus;
  authorId: number;
  createdAt: string;
  updatedAt: string;
}

export type ArticleStatus = 'draft' | 'published' | 'archived';

// 导出版本类型
export interface ArticleWithAuthor extends Article {
  author: User;
}
```

