## 数据保护

### 敏感文件处理

```typescript
// 标记敏感文件
async function uploadSensitiveFile(env: Env, file: File, userId: number): Promise<string> {
  const key = `sensitive/${userId}/${Date.now()}-${file.name}`;

  await env.R2_BUCKET.put(key, file.stream(), {
    httpMetadata: {
      cacheControl: 'private, no-store',
      contentType: file.type,
    },
    // 自定义元数据
    customMetadata: {
      uploadedBy: userId.toString(),
      uploadTime: new Date().toISOString(),
    },
  });

  return key;
}
```

### 文件删除安全

```typescript
async function deleteFile(env: Env, key: string, userId: number): Promise<boolean> {
  // 验证所有权
  const object = await env.R2_BUCKET.head(key);

  if (!object) {
    return false;
  }

  const uploadedBy = object.customMetadata?.uploadedBy;

  if (uploadedBy !== userId.toString()) {
    throw new ForbiddenError('无权删除此文件');
  }

  await env.R2_BUCKET.delete(key);
  return true;
}
```

