## 访问控制

### R2 自定义域安全

1. **配置访问策略**
```typescript
// 私有文件：需要签名URL
async function getSignedUploadUrl(env: Env, filename: string): Promise<string> {
  const key = `uploads/${Date.now()}-${filename}`;

  return await env.ASSETS.createMultipartUpload(key, {
    // 设置访问控制
    httpMetadata: {
      cacheControl: 'private',
      contentType: 'application/octet-stream',
    },
  });
}

// 公开文件：使用标准URL
async function getPublicUrl(env: Env, filename: string): string {
  return `https://${env.R2_BUCKET.publicUrl()}/${filename}`;
}
```

2. **防盗链配置**
```typescript
// 在 wrangler.jsonc 中配置
/*
{
  "r2_buckets": [
    {
      "binding": "ASSETS",
      "bucket_name": "anime-assets",
      "jurisdiction": "us-east-1"
    }
  ]
}
*/
```

### 签名URL机制

```typescript
interface SignedUrlParams {
  key: string;
  expiresIn: number; // 秒
}

async function generateSignedUrl(env: Env, params: SignedUrlParams): Promise<string> {
  const url = new URL(`${env.R2_BUCKET.publicUrl()}/${params.key}`);

  const expirationTime = Math.floor(Date.now() / 1000) + params.expiresIn;
  const signature = await generateSignature(params.key, expirationTime);

  url.searchParams.set('expires', expirationTime.toString());
  url.searchParams.set('signature', signature);

  return url.toString();
}

async function generateSignature(key: string, expires: number): Promise<string> {
  const data = `${key}:${expires}`;
  const keyBuffer = await crypto.subtle.importKey(
    'raw',
    new TextEncoder().encode(env.SECRET_KEY),
    { name: 'HMAC', hash: 'SHA-256' },
    false,
    ['sign']
  );

  const signature = await crypto.subtle.sign('HMAC', keyBuffer, new TextEncoder().encode(data));
  return btoa(String.fromCharCode(...new Uint8Array(signature)));
}
```

