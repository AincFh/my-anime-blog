## 上传处理流程

### 完整验证示例

```typescript
interface UploadValidationResult {
  valid: boolean;
  error?: string;
  sanitizedFilename?: string;
}

async function validateUpload(
  request: Request,
  env: Env
): Promise<UploadValidationResult> {
  const contentType = request.headers.get('Content-Type');
  const contentLength = request.headers.get('Content-Length');

  // 1. 检查Content-Type
  if (!contentType || !contentType.includes('multipart/form-data')) {
    return { valid: false, error: '无效的请求类型' };
  }

  // 2. 检查文件大小
  const size = contentLength ? parseInt(contentLength, 10) : 0;
  if (!validateFileSize(size, MAX_FILE_SIZE)) {
    return { valid: false, error: '文件大小超过限制' };
  }

  // 3. 解析表单数据
  const formData = await request.formData();
  const file = formData.get('file');

  if (!(file instanceof File)) {
    return { valid: false, error: '未找到上传文件' };
  }

  // 4. 验证MIME类型
  if (!validateMimeType(file.type)) {
    return { valid: false, error: '不支持的文件类型' };
  }

  // 5. 验证扩展名
  if (!validateExtension(file.name)) {
    return { valid: false, error: '文件扩展名不匹配' };
  }

  // 6. 生成安全的文件名
  const sanitizedFilename = sanitizeFilename(file.name);

  return { valid: true, sanitizedFilename };
}

function sanitizeFilename(filename: string): string {
  // 移除路径遍历攻击的潜在字符
  return filename
    .replace(/[^a-zA-Z0-9._-]/g, '_')
    .substring(0, 255);
}
```

