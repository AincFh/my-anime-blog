## 权限验证

### 权限检查装饰器模式

```typescript
type Permission = 'article:read' | 'article:write' | 'article:delete' | 'user:manage';

async function requirePermission(
  env: Env,
  sessionId: string,
  requiredPermission: Permission
): Promise<SessionData> {
  const session = await validateSession(env, sessionId);

  if (!session) {
    throw new UnauthorizedError('请先登录');
  }

  if (!session.permissions.includes(requiredPermission)) {
    throw new ForbiddenError('无此操作权限');
  }

  return session;
}
```

### 路由权限保护

```typescript
// 在 loader 或 action 中使用
export async function loader({ request, params, env }: LoaderFunctionArgs) {
  const cookieHeader = request.headers.get('Cookie');
  const sessionId = parseCookies(cookieHeader).session;

  const session = await requirePermission(env, sessionId, 'article:read');

  // 执行业务逻辑
  const articles = await getArticles(env);
  return Response.json({ articles });
}
```

