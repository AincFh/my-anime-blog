### 页面设计原则

```typescript
// ✅ 好的页面 - 干净，只组合组件
export async function loader({ env }: LoaderFunctionArgs) {
  const articles = await articleService.getFeatured(env);
  const user = await getOptionalUser(env);
  return { articles, user };
}

export default function HomePage({ loaderData }: Route.ComponentProps) {
  const { articles, user } = loaderData;
  return (
    <PublicLayout>
      <HeroSection user={user} />
      <ArticleGrid articles={articles} />
      <OnThisDay />
    </PublicLayout>
  );
}

// ❌ 坏的页面 - 塞满了业务逻辑和样式
