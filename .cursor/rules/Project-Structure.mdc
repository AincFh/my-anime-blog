### 服务层职责

```typescript
// ✅ 正确 - 服务层只处理业务逻辑
// app/services/article/create.server.ts
import { validateArticleData } from '~/utils/validation';
import { articleRepository } from '~/repositories/article.repository';

export async function createArticle(data: ArticleInput, env: Env) {
  // 1. 业务验证
  const validated = validateArticleData(data);
  
  // 2. 权限检查
  const session = await getSession(env);
  if (!session) {
    throw new UnauthorizedError('请先登录');
  }
  
  // 3. 调用数据访问层
  const article = await articleRepository.create(env.DB, validated);
  
  // 4. 触发副作用（通知、缓存等）
  await invalidateArticleCache(env, article.slug);
  
  return article;
}

// ❌ 错误 - 服务层直接操作数据库
export async function createArticle(data: ArticleInput, env: Env) {
  await env.DB
    .prepare('INSERT INTO articles (title) VALUES (?)')
    .bind(data.title)
    .run(); // 不要这样做！
}
```

## 数据访问层（Repository）

### 目录组织

```
app/repositories/
├── index.ts                   # 统一导出
├── base.repository.ts         # 基础仓储类
├── article.repository.ts      # 文章仓储
├── user.repository.ts         # 用户仓储
└── category.repository.ts     # 分类仓储
```

### Repository 实现规范

```typescript
// app/repositories/article.repository.ts
import type { D1Database } from '@cloudflare/workers-types';

export interface ArticleRow {
  id: number;
  title: string;
  slug: string;
  content: string;
  author_id: number;
  created_at: string;
}

export const articleRepository = {
  async findById(db: D1Database, id: number): Promise<Article | null> {
    const stmt = db.prepare('SELECT * FROM articles WHERE id = ?').bind(id);
    const result = await stmt.first<ArticleRow>();
    return result ? mapToArticle(result) : null;
  },
  
  async findBySlug(db: D1Database, slug: string): Promise<Article | null> {
    const stmt = db.prepare('SELECT * FROM articles WHERE slug = ?').bind(slug);
    const result = await stmt.first<ArticleRow>();
    return result ? mapToArticle(result) : null;
  },
  
  async create(db: D1Database, data: CreateArticleInput): Promise<Article> {
    const stmt = db.prepare(`
      INSERT INTO articles (title, slug, content, author_id)
      VALUES (?, ?, ?, ?)
    `).bind(data.title, data.slug, data.content, data.authorId);
    
    const result = await stmt.run();
    
    return {
      id: result.meta.last_row_id,
      ...data,
      createdAt: new Date().toISOString(),
    };
  },
};
```

